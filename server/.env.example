# -------------------------------------------------------
# DATABASE
# -------------------------------------------------------
# Local dev (Docker Compose) :
#   postgresql://auberge_user:auberge_password_2025@localhost:5432/auberge_db
# Staging/Prod (Neon, Supabase, Railway…) :
#   postgresql://USER:PASSWORD@HOST:5432/auberge_db?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/auberge_db"

# -------------------------------------------------------
# SERVER
# -------------------------------------------------------
PORT=3000
NODE_ENV=development   # development | production

# -------------------------------------------------------
# SECURITY
# -------------------------------------------------------
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-secret-min-32-chars"

# -------------------------------------------------------
# URLS
# -------------------------------------------------------
# URL publique du frontend (utilisé pour les liens email ex: reset password)
# Local dev :  http://localhost:5173
# Staging   :  https://auberge-espagnol.vercel.app
CLIENT_URL="http://localhost:5173"

# -------------------------------------------------------
# EMAIL (SMTP)
# -------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
# Gmail : créer un "App Password" dans les paramètres de compte Google
SMTP_PASS=your-app-password
SMTP_FROM="L'Auberge Espagnole <lauberge.espagnole.metz@gmail.com>"

# -------------------------------------------------------
# STRIPE
# -------------------------------------------------------
# Clés disponibles sur https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Optionnel en développement local (laisser vide si pas de webhook)
STRIPE_WEBHOOK_SECRET=whsec_...

# -------------------------------------------------------
# DEMO MODE
# -------------------------------------------------------
# Mettre à "true" pour désactiver l'inscription et la création de commandes
# Utile pour un déploiement de démonstration (staging)
DEMO_MODE=false

# -------------------------------------------------------
# CLOUDINARY (stockage des images produits)
# https://cloudinary.com/console
# -------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
